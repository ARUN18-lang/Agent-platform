# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Web search for the agent (at least one — Tavily is preferred if both are set)
# TAVILY_API_KEY=tvly-...
# BRAVE_SEARCH_API_KEY=BSA...
# Optional: abort hanging provider requests (default 25000 ms)
# WEB_SEARCH_FETCH_TIMEOUT_MS=25000
OPENAI_MODEL=gpt-4o
# Optional: max tool rounds before a forced text-only wrap-up (default 18, max 40)
# AGENT_MAX_ITERATIONS=24
# OpenAI allows at most 128 tools per request; list is deduped then trimmed if needed (default 128)
# AGENT_OPENAI_MAX_TOOLS=128
# Intent router (gpt-4o-mini): narrows tools per last user message — set 0 to disable
# AGENT_INTENT_ROUTER=1
# AGENT_ROUTER_MODEL=gpt-4o-mini

# GitHub MCP — set GITHUB_TOKEN; omit or set GITHUB_MCP_DISABLE=1 to skip loading this server
GITHUB_TOKEN=ghp_your_github_pat
# GITHUB_MCP_DISABLE=1
# Optional: your GitHub username or org — model uses this instead of invalid owner "me"
# GITHUB_DEFAULT_OWNER=your-login-or-org

# Slack MCP — set SLACK_BOT_TOKEN + SLACK_TEAM_ID to enable
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_TEAM_ID=T0...
# SLACK_CHANNEL_IDS=C0...,C1...

# Jira Cloud MCP — set all three to enable
# JIRA_BASE_URL=https://yourorg.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=your_atlassian_api_token

# Gmail MCP — opt-in (OAuth files or headless CLIENT_ID + CLIENT_SECRET + REFRESH_TOKEN)
# GMAIL_MCP_ENABLE=1
# Interactive re-auth (loads .env): from backend/ run  npm run gmail:auth
# Use a Google "Desktop" OAuth client JSON (or rename download to gcp-oauth.keys.json).
# GMAIL_AUTH_PORT=3456
# GMAIL_OAUTH_PATH=/absolute/path/to/client_secret_....json
# GMAIL_CREDENTIALS_PATH=/absolute/path/to/credentials.json   # same as GOOGLE_WORKSPACE_TOKEN_PATH if you share one file
# MCP_CONFIG_DIR=~/.gmail-mcp
# Do not set REFRESH_TOKEN if you want the file above to be the source of truth.
# CLIENT_ID=
# CLIENT_SECRET=
# REFRESH_TOKEN=

# WhatsApp MCP (Baileys / unofficial) — opt-in; QR link to your personal account
# WHATSAPP_MCP_ENABLE=1
# WHATSAPP_AUTH_DIR=/path/to/auth

# WhatsApp Business Cloud API (official Meta) — opt-in; separate from Baileys
# Meta → WhatsApp → API setup: Phone number ID + System User token (whatsapp_business_messaging)
# WHATSAPP_CLOUD_MCP_ENABLE=1
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# Optional: WhatsApp Business Account ID — enables whatsapp_cloud__list_whatsapp_message_templates
# WHATSAPP_CLOUD_WABA_ID=
# Optional default template language when the model omits language_code (default: en — not en_US)
# WHATSAPP_CLOUD_DEFAULT_LANGUAGE_CODE=en
# Optional Graph version (default v21.0)
# WHATSAPP_CLOUD_API_VERSION=v23.0

# Local Google Workspace MCP (Calendar + Meet + Gmail) — opt-in
# 1) GCP: enable "Google Calendar API" + "Gmail API" for this project.
# 2) OAuth consent screen: add scopes (exact URLs):
#    https://www.googleapis.com/auth/calendar.events
#    https://www.googleapis.com/auth/gmail.send
#    https://www.googleapis.com/auth/gmail.readonly
# 3) Web OAuth client: Authorized redirect URI must include https://developers.google.com/oauthplayground
# 4) Revoke old access: https://myaccount.google.com/permissions — remove this app.
# 5) OAuth Playground: gear → use your client id/secret → select those scopes → Authorize → Exchange for tokens → copy refresh_token.
# 6) Put refresh_token + client id/secret below (gmail-only tokens will NOT work for Meet).
# GOOGLE_WORKSPACE_MCP_ENABLE=1
# GOOGLE_WORKSPACE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_WORKSPACE_CLIENT_SECRET=...
# GOOGLE_WORKSPACE_REFRESH_TOKEN=...
# Or JSON file containing "refresh_token":
# GOOGLE_WORKSPACE_TOKEN_PATH=/Users/you/.gmail-mcp/credentials.json

# YouTube MCP (@mrsknetwork/ytmcp) — opt-in; dependency in backend/package.json
# YOUTUBE_MCP_ENABLE=1
# YOUTUBE_API_KEY=...   # YouTube Data API v3 — required for search_content and most metadata tools to return data
# Transcript tool: after npm install run  npm run yt-dlp:fetch  in backend/ (downloads bin into yt-dlp-exec), or:
# YOUTUBE_DL_DIR=/opt/homebrew/bin   # Apple Silicon + brew install yt-dlp
# YOUTUBE_DL_DIR=/usr/local/bin      # Intel Mac + brew install yt-dlp
# Optional OAuth for subscriptions/private data (see ytmcp redirect URI docs):
# YOUTUBE_GOOGLE_CLIENT_ID=
# YOUTUBE_GOOGLE_CLIENT_SECRET=

# Mermaid MCP (@narasimhaponnada/mermaid-mcp-server) — opt-in; bundled in backend/package.json (uses Puppeteer for some renders)
# MERMAID_MCP_ENABLE=1

# PowerPoint MCP (local rich-ppt-mcp + pptxgenjs) — opt-in; native layouts, no Playwright
# PPT_MCP_ENABLE=1
# Decks are written to the server user's Downloads folder (e.g. ~/Downloads on macOS)
# Optional: allow download API to serve files from another directory (absolute path)
# PRESENTATION_DOWNLOAD_ROOT=

# E2B Code Interpreter MCP (@e2b/mcp-server) — opt-in; cloud sandboxes (see e2b.dev pricing)
# E2B_MCP_ENABLE=1
# E2B_API_KEY=e2b_...

# Chat CSV/Excel attachments — optional tuning
# Uploads are stored under the OS temp dir (survives nodemon restarts) for 2 hours.
# Max characters of CSV text injected into the agent context per upload (default 320000, cap 450000)
# AGENT_UPLOAD_MAX_CSV_CHARS=320000
# Mini-planner before the main agent when attachments are present (set 0 to skip)
# AGENT_DATA_PLANNER=1
# AGENT_DATA_PLANNER_MODEL=gpt-4o-mini

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Sarvam — speech → English text (voice input in chat); requires MONGODB_URI for storage
# https://docs.sarvam.ai/api-reference-docs/speech-to-text-translate/translate
# Create a key at https://dashboard.sarvam.ai/ → API Keys (not the same as other vendors’ keys).
# SARVAM_API_SUBSCRIPTION_KEY=
# Alias (either works):
# SARVAM_API_KEY=

# MongoDB — required for sign up / sign in; also used for conversation history when set
# MONGODB_URI=mongodb://127.0.0.1:27017
# Optional database name (default: agent_platform)
# MONGODB_DB=agent_platform

# Auth — JWT signing secret (use a long random string in production)
# JWT_SECRET=change-me-to-a-long-random-string
# Optional token lifetime (default 7d)
# JWT_EXPIRES_IN=7d
